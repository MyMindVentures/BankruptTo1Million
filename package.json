{
  "name": "bankrupt-to-1-million",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "npm@10.8.2",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "start": "node server.mjs",
    "lint": "eslint .",
    "preview": "vite preview --host 0.0.0.0 --port ${PORT:-4173}",
    "typecheck": "tsc -b --pretty false",
    "test": "node --experimental-strip-types --test tests/*.test.mjs",
    "verify:i18n": "node scripts/verify-public-i18n.mjs --skip-db",
    "verify:i18n:live": "node scripts/verify-public-i18n.mjs --require-db",
    "generate:i18n-keys": "node scripts/generate-public-i18n-keys.mjs",
    "generate:registry-seed": "node scripts/generate-registry-seed.mjs",
    "precommit": "npm run lint && npm run typecheck && npm test && npm run verify:i18n"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "motion": "^12.23.12",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "6.0.3",
    "vite": "8.1.5",
    "typescript": "5.7.2",
    "eslint": "9.17.0",
    "@eslint/js": "9.17.0",
    "typescript-eslint": "8.18.2",
    "eslint-plugin-react-hooks": "5.1.0",
    "eslint-plugin-react-refresh": "0.4.16",
    "globals": "15.14.0",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "@types/node": "^22.12.0"
  },
  "engines": {
    "node": ">=20.19.0 <21"
  }
}
